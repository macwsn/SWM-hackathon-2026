GEMINI_API_KEY=your_gemini_api_key_here

# Set to false to use real integrations
USE_MOCK_GEMINI=true
USE_MOCK_SMELTER=true
USE_MOCK_LOCATION=true
USE_MOCK_DEPTH=false

# Depth model settings
# Options: cpu, cuda, mps
DEPTH_MODEL_DEVICE=cpu
# Seconds between depth inferences (0.5 = 2 FPS)
DEPTH_INFERENCE_INTERVAL=0.5
# Obstacle warning thresholds (meters)
OBSTACLE_THRESHOLD_INDOOR=1.5
OBSTACLE_THRESHOLD_OUTDOOR=2.0

# Paths
VIDEO_INPUT_DIR=./video_input
MODEL_WEIGHTS_DIR=./models
