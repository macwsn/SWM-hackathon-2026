# ═══════════════════════════════════════════════════════════════
# Backend Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this to .env and customize with your actual values

# ───────────────────────────────────────────────────────────────
# API Keys
# ───────────────────────────────────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ───────────────────────────────────────────────────────────────
# Mock Services
# ───────────────────────────────────────────────────────────────
# USE_MOCK_GEMINI: Set to false when you have a valid GEMINI_API_KEY
USE_MOCK_GEMINI=true

# Auto-switch depth mode using Gemini every few minutes.
AUTO_DEPTH_MODE_WITH_GEMINI=true
AUTO_DEPTH_MODE_INTERVAL_SECONDS=180
AUTO_DEPTH_MODE_DEFAULT=unknown

# USE_MOCK_LOCATION: Set to false to use real GPS from mobile browser
# IMPORTANT: Real GPS requires HTTPS on mobile devices!
USE_MOCK_LOCATION=false

# USE_MOCK_SMELTER: WebRTC streaming (not currently used)
USE_MOCK_SMELTER=true

# USE_MOCK_DEPTH: Should always be false (uses real Depth Anything V2)
USE_MOCK_DEPTH=false

# ───────────────────────────────────────────────────────────────
# CORS Configuration
# ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Add your mobile testing URL (ngrok or local IP with HTTPS)
CORS_ORIGINS=http://localhost:5173,https://localhost:5173,http://localhost:3000

# ───────────────────────────────────────────────────────────────
# Redis Connection
# ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────────
# Depth Model Settings
# ───────────────────────────────────────────────────────────────
# Device: cpu, cuda, or mps (macOS: use cpu, auto-detects MPS)
DEPTH_MODEL_DEVICE=cpu

# Inference interval in seconds (0.5 = 2 FPS)
DEPTH_INFERENCE_INTERVAL=0.5

# Obstacle thresholds in meters
OBSTACLE_THRESHOLD_INDOOR=1.5
OBSTACLE_THRESHOLD_OUTDOOR=2.0

# Processing resolution (smaller = faster)
DEPTH_PROC_W=480
DEPTH_PROC_H=360

# ───────────────────────────────────────────────────────────────
# File Paths
# ───────────────────────────────────────────────────────────────
VIDEO_INPUT_DIR=./video_input
MODEL_WEIGHTS_DIR=./models

# ───────────────────────────────────────────────────────────────
# Text-to-Speech (edge-tts)
# ───────────────────────────────────────────────────────────────
TTS_VOICE=pl-PL-ZofiaNeural
TTS_LANGUAGE=pl-PL
