# ═══════════════════════════════════════════════════════════════
# Blind Assistant - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Usage: cp .env.example .env
#
# QUICK SETUP GUIDE:
# 1. Copy this file: cp .env.example .env
# 2. Replace GEMINI_API_KEY with your actual key from https://makersuite.google.com/app/apikey
# 3. Set USE_MOCK_LOCATION=false to use real GPS from mobile
# 4. Update CORS_ORIGINS if accessing from different domains/IPs
# 5. On macOS, keep DEPTH_MODEL_DEVICE=cpu (Apple Silicon uses MPS automatically)
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# API Keys (REQUIRED for production)
# ───────────────────────────────────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ───────────────────────────────────────────────────────────────
# Development vs Production
# ───────────────────────────────────────────────────────────────
# Set to "development" or "production"
NODE_ENV=development

# ───────────────────────────────────────────────────────────────
# Mock Services (for testing without external dependencies)
# ───────────────────────────────────────────────────────────────
# USE_MOCK_GEMINI: Set to false when you have a valid GEMINI_API_KEY
# - true:  Uses predefined Polish responses (no API calls)
# - false: Uses real Google Gemini API for scene descriptions
USE_MOCK_GEMINI=false

# USE_MOCK_LOCATION: Set to false to use real GPS from mobile device
# - true:  Simulates GPS movement around Kraków city center
# - false: Uses real browser GPS (navigator.geolocation) from User panel
#          IMPORTANT: Mobile requires HTTPS for GPS access!
USE_MOCK_LOCATION=false

# USE_MOCK_SMELTER: WebRTC streaming (not currently used)
USE_MOCK_SMELTER=true

# USE_MOCK_DEPTH: Should always be false (real Depth Anything V2 model)
USE_MOCK_DEPTH=false

# ───────────────────────────────────────────────────────────────
# CORS Configuration (Comma-separated list)
# ───────────────────────────────────────────────────────────────
# Development: Includes Vite dev server (5173) and production build (3000)
# Production: Add your domain, e.g., https://blind-assistant.yourdomain.com
#
# For mobile testing over local network (e.g., ngrok or local IP):
# Add: https://your-ngrok-url.ngrok.io or https://192.168.1.x:5173
CORS_ORIGINS=http://localhost:5173,https://localhost:5173,http://localhost:3000,http://localhost:80

# ───────────────────────────────────────────────────────────────
# Depth Model Configuration (Depth Anything V2)
# ───────────────────────────────────────────────────────────────
# Device for depth inference:
# - cpu:  Works on all systems (slower but compatible)
# - cuda: NVIDIA GPU (requires CUDA toolkit + GPU)
# - mps:  Apple Silicon GPU (M1/M2/M3 - automatic fallback from cpu)
#
# IMPORTANT: On macOS, always use cpu (PyTorch auto-detects MPS)
DEPTH_MODEL_DEVICE=cpu

# Inference interval: Seconds between depth predictions
# - 0.5 = 2 FPS (recommended for CPU)
# - 0.25 = 4 FPS (possible with GPU)
# - Lower = faster updates but higher CPU/GPU usage
DEPTH_INFERENCE_INTERVAL=0.5

# Obstacle warning thresholds in meters
# Alerts trigger when detected object is closer than threshold
OBSTACLE_THRESHOLD_INDOOR=1.5   # Indoor: 1.5 meters
OBSTACLE_THRESHOLD_OUTDOOR=2.0  # Outdoor: 2.0 meters

# Frame processing resolution (downscaled before inference)
# Lower resolution = faster processing, lower accuracy
# Recommended: 480x360 for CPU, 640x480 for GPU
DEPTH_PROC_W=480
DEPTH_PROC_H=360

# ───────────────────────────────────────────────────────────────
# Database Configuration
# ───────────────────────────────────────────────────────────────
# Redis: Used for WebSocket message routing and caching
REDIS_URL=redis://redis:6379

# PostgreSQL: User sessions, location history, alerts (optional for MVP)
POSTGRES_USER=blind_assistant
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_DB=blind_assistant_db

# ───────────────────────────────────────────────────────────────
# File Storage (MinIO - S3-compatible)
# ───────────────────────────────────────────────────────────────
# Optional: For storing video frames for later analysis
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=blind-assistant-frames

# ───────────────────────────────────────────────────────────────
# Text-to-Speech Configuration
# ───────────────────────────────────────────────────────────────
# Using edge-tts (Microsoft Edge TTS - Free, no API key required)
# Voice options: pl-PL-ZofiaNeural (female), pl-PL-MarekNeural (male)
TTS_VOICE=pl-PL-ZofiaNeural
TTS_LANGUAGE=pl-PL

# ───────────────────────────────────────────────────────────────
# File Paths (Inside Container)
# ───────────────────────────────────────────────────────────────
VIDEO_INPUT_DIR=./video_input
MODEL_WEIGHTS_DIR=./models

# ───────────────────────────────────────────────────────────────
# Logging
# ───────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ───────────────────────────────────────────────────────────────
# Mobile Testing (HTTPS Required for Camera + GPS)
# ───────────────────────────────────────────────────────────────
# Option 1: Use ngrok for HTTPS tunnel
# - Install: brew install ngrok (macOS) or snap install ngrok (Linux)
# - Run: ngrok http 5173
# - Access: https://your-random-id.ngrok.io
# - Update CORS_ORIGINS with ngrok URL
#
# Option 2: Use mkcert for local HTTPS
# - Install: brew install mkcert (macOS)
# - Setup: mkcert -install && mkcert localhost 192.168.1.x
# - Enable HTTPS in vite.config.ts
# - Access: https://192.168.1.x:5173 (use your local IP)
#
# IMPORTANT: Browser GPS requires HTTPS on mobile devices!

