# ═══════════════════════════════════════════════════════════════
# Blind Assistant - Docker Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# External API Keys
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
NGROK_AUTHTOKEN=your_ngrok_token_here
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ──────────────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=blind_assistant
POSTGRES_URL=postgresql://postgres:changeme_in_production@postgres:5432/blind_assistant

# ──────────────────────────────────────────────────────────────
# Redis Configuration
# ──────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_MAX_CONNECTIONS=50

# ──────────────────────────────────────────────────────────────
# MinIO (S3-compatible storage)
# ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=blind-assistant-frames

# ──────────────────────────────────────────────────────────────
# Streaming Gateway Configuration
# ──────────────────────────────────────────────────────────────
STREAM_GW_PORT=8001
FRAME_DOWNSAMPLE_WIDTH=480
FRAME_DOWNSAMPLE_HEIGHT=360
MAX_FRAME_QUEUE_SIZE=100
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=turn:your-turn-server:3478
WEBRTC_TURN_USERNAME=username
WEBRTC_TURN_PASSWORD=password

# ──────────────────────────────────────────────────────────────
# Depth Worker A Configuration (GPU Inference)
# ──────────────────────────────────────────────────────────────
DEPTH_WORKER_A_DEVICE=cuda  # Options: cuda, cpu, mps
DEPTH_WORKER_A_BATCH_SIZE=1
INDOOR_MODEL_ID=depth-anything/Depth-Anything-V2-Metric-Indoor-Small-hf
OUTDOOR_MODEL_ID=depth-anything/Depth-Anything-V2-Metric-Outdoor-Small-hf
HUGGINGFACE_CACHE=/models/cache

# ──────────────────────────────────────────────────────────────
# Depth Worker B Configuration (Obstacle Detection)
# ──────────────────────────────────────────────────────────────
OBSTACLE_THRESHOLD_INDOOR=1.5  # meters
OBSTACLE_THRESHOLD_OUTDOOR=2.0  # meters
ALERT_THROTTLE_SECONDS=2.0
OBSTACLE_MIN_AREA_PIXELS=500  # Minimum obstacle size to trigger alert

# ──────────────────────────────────────────────────────────────
# Orchestrator Configuration
# ──────────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=8002
TTS_LANGUAGE=pl-PL
TTS_VOICE=pl-PL-ZofiaNeural  # Azure Edge-TTS voice
ALERT_HISTORY_LIMIT=100
GEMINI_SERVICE_URL=http://gemini-service:8003
MAP_SERVICE_URL=http://map-service:8004

# ──────────────────────────────────────────────────────────────
# Gemini Service Configuration
# ──────────────────────────────────────────────────────────────
GEMINI_MODEL_NAME=gemini-1.5-pro
GEMINI_REQUEST_TIMEOUT=30
GEMINI_CACHE_TTL_SECONDS=3600
GEMINI_MAX_RETRIES=3

# ──────────────────────────────────────────────────────────────
# Map Service Configuration
# ──────────────────────────────────────────────────────────────
NOMINATIM_URL=https://nominatim.openstreetmap.org
MAP_USER_AGENT=BlindAssistant/1.0
MAP_CACHE_TTL_SECONDS=3600
POI_SEARCH_RADIUS_METERS=500

# ──────────────────────────────────────────────────────────────
# Logging Configuration
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # Options: json, plain
SENTRY_DSN=  # Optional: Sentry error tracking

# ──────────────────────────────────────────────────────────────
# Monitoring Configuration
# ──────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_EXPORT_INTERVAL_SECONDS=15

# ──────────────────────────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────────────────────────
USE_MOCK_GEMINI=false
USE_MOCK_SMELTER=false
USE_MOCK_LOCATION=false
USE_MOCK_DEPTH=false
ENABLE_FRAME_ARCHIVAL=true  # Store frames to MinIO
ENABLE_TELEMETRY=true

# ──────────────────────────────────────────────────────────────
# Security Configuration
# ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme_random_256bit_key
JWT_EXPIRATION_HOURS=24
CORS_ALLOWED_ORIGINS=https://blind-assistant.yourdomain.com,https://localhost:5173
RATE_LIMIT_PER_MINUTE=60

# ──────────────────────────────────────────────────────────────
# Development/Production Toggle
# ──────────────────────────────────────────────────────────────
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=false

